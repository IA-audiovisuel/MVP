  <data key="d5">"foundation, social order"</data>
  <data key="d6">chunk-b3da432a99878091a368929c8cf97145</data>
</edge>
<edge source="&quot;CORTEX PRÉFRONTAL&quot;" target="&quot;TRAC&quot;">
  <data key="d3">7.0</data>
