  <data key="d5">"cognitive function, value flexibility"</data>
  <data key="d6">chunk-696e6532b6fd5570de4d3650523b608e</data>
</edge>
<edge source="&quot;CORTEX PRÉFRONTAL&quot;" target="&quot;MALADIES MENTALES&quot;">
  <data key="d3">6.0</data>
