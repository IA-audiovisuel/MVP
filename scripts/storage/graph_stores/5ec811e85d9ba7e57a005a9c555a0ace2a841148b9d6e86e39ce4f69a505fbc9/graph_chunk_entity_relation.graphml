  <data key="d4">"The prefrontal cortex is the neural substrate for working memory, enabling the maintenance and manipulation of information for future actions."</data>
  <data key="d5">"cognitive function, neural substrate"</data>
  <data key="d6">chunk-f736994c87df07b89d48f895b0862dfe</data>
</edge>
