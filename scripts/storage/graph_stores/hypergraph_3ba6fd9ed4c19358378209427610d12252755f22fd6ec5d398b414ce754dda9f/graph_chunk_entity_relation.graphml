  <data key="d6">chunk-2db9d3bd36cd8348cea1609debc74d1b</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Si on ne s'engage pas résolument dans cette politique d'innovation et de réindustrialisation, nous ne pourrons pas soutenir notre modèle social.&quot;" target="&quot;POLITIQUE D'INNOVATION&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-554162400a0903cf6577c3382c554e55</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Si on ne s'engage pas résolument dans cette politique d'innovation et de réindustrialisation, nous ne pourrons pas soutenir notre modèle social.&quot;" target="&quot;RÉINDUSTRIALISATION&quot;">
