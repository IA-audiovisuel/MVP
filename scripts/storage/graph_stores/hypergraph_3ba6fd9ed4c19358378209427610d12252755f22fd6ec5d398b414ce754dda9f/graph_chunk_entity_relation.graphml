  <data key="d5">90.0</data>
  <data key="d6">chunk-cb1a7d5ac51b02dda41de156cbdd863c</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Some are almost more worried than you today, because with this increase in debts/rights, there are sectors that can no longer really be funded.&quot;" target="&quot;SECTEURS&quot;">
