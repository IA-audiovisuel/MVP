  <data key="d5">85.0</data>
  <data key="d6">chunk-a86e5a0f4c9ea30c5afa45797a7ab900</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Ça sera quand même à moyen et long terme les moyens de pouvoir nous permettre d'offrir un bon système social&quot;" target="&quot;BON SYSTÈME SOCIAL&quot;">
  <data key="d5">90.0</data>
  <data key="d6">chunk-a86e5a0f4c9ea30c5afa45797a7ab900</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;C'est une manière d'être progressiste différente de 'pas de croissance, pas d'innovation'.&quot;" target="&quot;GAUCHE RÉTROGRADE&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-2db9d3bd36cd8348cea1609debc74d1b</data>
</edge>
