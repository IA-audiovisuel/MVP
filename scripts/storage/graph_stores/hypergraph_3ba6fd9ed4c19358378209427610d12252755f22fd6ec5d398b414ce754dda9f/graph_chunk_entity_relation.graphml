  <data key="d6">chunk-554162400a0903cf6577c3382c554e55</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;How do we refound the social contract in a society where you have today 18 and tomorrow 20 then 21 million retirees?&quot;" target="&quot;SOCIAL CONTRACT&quot;">
  <data key="d5">90.0</data>
  <data key="d6">chunk-24d742eda69960bb061851a250ee4933</data>
</edge>
