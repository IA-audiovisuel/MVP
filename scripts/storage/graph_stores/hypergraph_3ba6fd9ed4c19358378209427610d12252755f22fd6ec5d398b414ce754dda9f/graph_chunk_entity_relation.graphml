</edge>
<edge source="&lt;hyperedge&gt;&quot;Life expectancy will continue to rise. The quality of care is there.&quot;" target="&quot;LIFE EXPECTANCY&quot;">
  <data key="d5">90.0</data>
  <data key="d6">chunk-24d742eda69960bb061851a250ee4933</data>
</edge>
