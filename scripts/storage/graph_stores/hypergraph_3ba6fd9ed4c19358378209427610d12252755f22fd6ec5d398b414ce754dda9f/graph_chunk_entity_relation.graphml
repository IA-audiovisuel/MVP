  <data key="d6">chunk-24d742eda69960bb061851a250ee4933</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Police stations are in a deplorable state, Nicolas Dufourcq you say.&quot;" target="&quot;ÉTAT DÉPLORABLE&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-cb1a7d5ac51b02dda41de156cbdd863c</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Il aime bien Nicolas Bavray, que je respecte beaucoup, être un peu catastrophiste&quot;" target="&quot;CATASTROPHISTE&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-a86e5a0f4c9ea30c5afa45797a7ab900</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;On croit beaucoup dans le fait qu'il faut à la fois innover et être inclusif.&quot;" target="&quot;INNOVATION ET INCLUSION&quot;">
  <data key="d5">90.0</data>
  <data key="d6">chunk-2db9d3bd36cd8348cea1609debc74d1b</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;C'est pour ça, Nicolas Dufourcq, que vous parlez de la nécessité d'une écologie de l'État-providence.&quot;" target="&quot;ÉCOLOGIE DE L'ÉTAT-PROVIDENCE&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-554162400a0903cf6577c3382c554e55</data>
</edge>
