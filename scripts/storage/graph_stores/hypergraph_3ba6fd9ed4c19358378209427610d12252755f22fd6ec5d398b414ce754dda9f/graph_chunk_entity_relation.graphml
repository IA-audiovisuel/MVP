  <data key="d6">chunk-cb1a7d5ac51b02dda41de156cbdd863c</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Ça sera quand même à moyen et long terme les moyens de pouvoir nous permettre d'offrir un bon système social&quot;" target="&quot;MOYEN ET LONG TERME&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-a86e5a0f4c9ea30c5afa45797a7ab900</data>
</edge>
