  <data key="d6">chunk-554162400a0903cf6577c3382c554e55</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;With another of our chimeras which is France is fertile, birth rates will never fall. They are falling and they will continue to fall.&quot;" target="&quot;FRANCE&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-24d742eda69960bb061851a250ee4933</data>
</edge>
