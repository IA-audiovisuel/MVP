</edge>
<edge source="&lt;hyperedge&gt;&quot;Nicolas Bavray said that France is today on the path to third-worldization.&quot;" target="&quot;DIAGNOSTIC&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-cb1a7d5ac51b02dda41de156cbdd863c</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Mais il faut qu'on se réveille et qu'on se relève&quot;" target="&quot;RÉVEIL&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-a86e5a0f4c9ea30c5afa45797a7ab900</data>
</edge>
