  <data key="d6">chunk-2db9d3bd36cd8348cea1609debc74d1b</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;C'est le seul moyen de soutenir notre modèle social. Nous ne pourrons pas soutenir notre modèle social si nous ne relevons pas le défi du déclin technologique.&quot;" target="&quot;DÉFI&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-554162400a0903cf6577c3382c554e55</data>
</edge>
