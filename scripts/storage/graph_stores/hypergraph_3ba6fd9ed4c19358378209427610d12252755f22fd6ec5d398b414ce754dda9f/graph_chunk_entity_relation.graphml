  <data key="d6">chunk-cb1a7d5ac51b02dda41de156cbdd863c</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Donc, je crois qu'il y a les leviers que mentionne Nicolas, mais à plus long terme&quot;" target="&quot;LEVIERS&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-a86e5a0f4c9ea30c5afa45797a7ab900</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;On pense qu'il faut un État qui se pose présent.&quot;" target="&quot;ÉTAT PRÉSENT&quot;">
