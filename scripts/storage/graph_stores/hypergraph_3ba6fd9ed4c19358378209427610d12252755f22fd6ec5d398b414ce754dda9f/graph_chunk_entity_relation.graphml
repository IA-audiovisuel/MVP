</edge>
<edge source="&lt;hyperedge&gt;&quot;C'est ça vraiment qui nous sépare de cette gauche rétrograde à mon avis.&quot;" target="&quot;GAUCHE RÉTROGRADE&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-2db9d3bd36cd8348cea1609debc74d1b</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Raymond Aron, en 1932, avait fait une... frais et mollus de l'école normale. Il avait fait un séjour d'un an en Allemagne au ministère des Aff&quot;" target="&quot;ÉCOLE NORMALE&quot;">
  <data key="d5">85.0</data>
