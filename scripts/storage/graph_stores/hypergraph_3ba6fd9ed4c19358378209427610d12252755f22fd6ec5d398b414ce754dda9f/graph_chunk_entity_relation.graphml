</edge>
<edge source="&lt;hyperedge&gt;&quot;Philippe Aghion believes everything must be put on the table because there are abuses everywhere.&quot;" target="&quot;ABUS UN PEU PARTOUT&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-cb1a7d5ac51b02dda41de156cbdd863c</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Mais je crois aussi, donc, augmentation du taux d'emploi et augmentation de la productivité&quot;" target="&quot;AUGMENTATION&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-a86e5a0f4c9ea30c5afa45797a7ab900</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;La mobilité sociale est au cœur de notre agenda progressiste.&quot;" target="&quot;AGENDA PROGRESSISTE&quot;">
  <data key="d5">85.0</data>
  <data key="d6">chunk-2db9d3bd36cd8348cea1609debc74d1b</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;L'innovation de rupture se fait beaucoup plus en Chine et aux Etats-Unis que chez nous.&quot;" target="&quot;INNOVATION DE RUPTURE&quot;">
  <data key="d5">90.0</data>
  <data key="d6">chunk-554162400a0903cf6577c3382c554e55</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;We must first agree in the public debate on the consequences of the dramatic aging of French society.&quot;" target="&quot;AGING&quot;">
  <data key="d5">90.0</data>
  <data key="d6">chunk-24d742eda69960bb061851a250ee4933</data>
