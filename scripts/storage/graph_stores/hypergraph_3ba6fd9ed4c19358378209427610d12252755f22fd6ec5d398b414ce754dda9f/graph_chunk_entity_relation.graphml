  <data key="d6">chunk-24d742eda69960bb061851a250ee4933</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;Otherwise, politically, it will not work.&quot;" target="&quot;FONCTIONNEMENT POLITIQUE&quot;">
