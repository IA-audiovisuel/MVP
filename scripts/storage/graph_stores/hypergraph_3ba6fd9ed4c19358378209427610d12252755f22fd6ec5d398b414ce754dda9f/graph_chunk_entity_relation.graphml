  <data key="d6">chunk-554162400a0903cf6577c3382c554e55</data>
</edge>
<edge source="&lt;hyperedge&gt;&quot;The service they bought by paying their contribution each month is not that service. They bought 15 years of retirement and they get 30.&quot;" target="&quot;CONTRIBUTION&quot;">
  <data key="d5">90.0</data>
  <data key="d6">chunk-24d742eda69960bb061851a250ee4933</data>
</edge>
